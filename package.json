{
  "name": "components-heap-error",
  "version": "0.0.1",
  "license": "MIT",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "lsd:module": "https://linkedsoftwaredependencies.org/bundles/npm/components-heap-error",
  "lsd:components": "dist/components/components.jsonld",
  "lsd:contexts": {
    "https://linkedsoftwaredependencies.org/bundles/npm/components-heap-error/^0.0.0/components/context.jsonld": "dist/components/context.jsonld"
  },
  "lsd:importPaths": {
    "https://linkedsoftwaredependencies.org/bundles/npm/components-heap-error/^0.0.0/components/": "dist/components/",
    "https://linkedsoftwaredependencies.org/bundles/npm/components-heap-error/^0.0.0/config/": "config/",
    "https://linkedsoftwaredependencies.org/bundles/npm/components-heap-error/^0.0.0/dist/": "dist/"
  },
  "scripts": {
    "start": "node bin/run.js",
    "build": "npm run build:ts && npm run build:components",
    "build:components": "componentsjs-generator -s src -c dist/components -r che",
    "build:ts": "tsc"
  },
  "dependencies": {
    "componentsjs": "^6.3.0"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.4",
    "componentsjs-generator": "^4.3.0",
    "typescript": "^5.5.4"
  }
}
